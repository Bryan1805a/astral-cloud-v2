enum AuditResult {
  SUCCESS
  FAILURE
}

model AuditLog {
  id         String      @id @default(uuid())
  userId     String?
  action     AuditAction
  targetType String      @db.VarChar(32)
  targetId   String
  result     AuditResult
  metadata   Json?
  ipAddress  String      @db.VarChar(45)
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}

model VpsTag {
  id        String   @id @default(uuid())
  userId    String
  name      String   @db.VarChar(32)
  color     String?  @db.VarChar(7)
  createdAt DateTime @default(now())

  user       User        @relation(fields: [userId], references: [id])
  serverTags ServerTag[]

  @@unique([userId, name])
  @@index([userId])
}

model ServerTag {
  serverId String
  tagId    String

  server ServerInstance @relation(fields: [serverId], references: [id])
  tag    VpsTag         @relation(fields: [tagId], references: [id])

  @@id([serverId, tagId])
}

model SystemSetting {
  id              String            @id @default(uuid())
  key             String            @unique @db.VarChar(64)
  value           String            @db.Text
  type            SystemSettingType
  label           String            @db.VarChar(128)
  description     String?           @db.VarChar(255)
  isImmutable     Boolean           @default(false)
  updatedByUserId String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  updatedBy User? @relation(fields: [updatedByUserId], references: [id])
}

enum SystemSettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

model EmailTemplate {
  id        String   @id @default(uuid())
  code      String   @unique @db.VarChar(64)
  name      String   @db.VarChar(128)
  subject   String   @db.VarChar(255)
  htmlBody  String   @db.Text
  textBody  String?  @db.Text
  variables Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum AnnouncementSeverity {
  INFO
  WARNING
  CRITICAL
}

model Announcement {
  id              String              @id @default(uuid())
  title           String              @db.VarChar(128)
  body            String              @db.Text
  severity        AnnouncementSeverity @default(INFO)
  isActive        Boolean             @default(true)
  startsAt        DateTime?
  endsAt          DateTime?
  createdByUserId String
  createdAt       DateTime            @default(now())

  createdBy User @relation(fields: [createdByUserId], references: [id])
}

model TaxRate {
  id        String   @id @default(uuid())
  regionId  String
  name      String   @db.VarChar(64)
  rate      Decimal  @db.Decimal(5, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  region Region @relation(fields: [regionId], references: [id])

  @@unique([regionId])
}

model FeatureFlag {
  id          String    @id @default(uuid())
  key         String    @unique @db.VarChar(64)
  description String    @db.VarChar(255)
  enabled     Boolean   @default(false)
  rules       Json?
  lastEvaluatedAt DateTime?
  createdByUserId  String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy User @relation(fields: [createdByUserId], references: [id])
}

model ImpersonationSession {
  id            String    @id @default(uuid())
  adminUserId   String
  targetUserId  String
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  ipAddress     String    @db.VarChar(45)

  admin  User @relation("ImpersonationAdmin", fields: [adminUserId], references: [id])
  target User @relation("ImpersonationTarget", fields: [targetUserId], references: [id])

  @@index([adminUserId])
}

enum TermsType {
  TOS
  PRIVACY_POLICY
}

model TermsAcceptance {
  id        String    @id @default(uuid())
  userId    String
  termsType TermsType
  version   String    @db.VarChar(32)
  acceptedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model CookieConsent {
  id          String   @id @default(uuid())
  userId      String?
  sessionId   String?  @db.VarChar(64)
  preferences Json
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

enum GdprRequestType {
  EXPORT
  DELETE
}

enum GdprRequestStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model GdprRequest {
  id          String            @id @default(uuid())
  userId      String
  type        GdprRequestType
  status      GdprRequestStatus @default(PENDING)
  downloadUrl String?           @db.VarChar(512)
  completedAt DateTime?
  expiresAt   DateTime
  createdAt   DateTime          @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

enum AbuseReportType {
  DMCA
  SPAM
  MALWARE
  CRYPTO_MINING
  PHISHING
  OTHER
}

enum AbuseReportStatus {
  PENDING_REVIEW
  INVESTIGATING
  VALIDATED
  DISMISSED
  SUSPENDED
  RESOLVED
}

model AbuseReport {
  id                String            @id @default(uuid())
  reporterUserId    String?
  serverId          String?
  type              AbuseReportType
  description       String            @db.Text
  evidence          String?           @db.Text
  status            AbuseReportStatus @default(PENDING_REVIEW)
  resolution        String?           @db.Text
  reviewedByUserId  String?
  createdAt         DateTime          @default(now())
  resolvedAt        DateTime?

  reporter    User?            @relation("AbuseReporter", fields: [reporterUserId], references: [id])
  server      ServerInstance?  @relation(fields: [serverId], references: [id])
  reviewedBy  User?            @relation("AbuseReviewer", fields: [reviewedByUserId], references: [id])

  @@index([status])
  @@index([serverId])
}

model Snapshot {
  id             String   @id @default(uuid())
  userId         String
  sourceServerId String?
  label          String   @db.VarChar(64)
  sizeGB         Int
  createdAt      DateTime @default(now())

  user         User             @relation(fields: [userId], references: [id])
  sourceServer ServerInstance?  @relation("SnapshotSource", fields: [sourceServerId], references: [id])
  servers      ServerInstance[] @relation("SnapshotServers")

  @@index([userId])
}
